{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project item (video, website, game, etc.)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "website", "game", "graphics"] },
        "url": { "type": "string" },
        "posterUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "url", "createdAt"]
    }
  },
  "firestore": {
    "projects/{projectId}": {
      "schema": "Project",
      "description": "List of portfolio projects"
    }
  }
}
