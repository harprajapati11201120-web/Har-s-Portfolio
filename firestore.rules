rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global sync active without Firebase Auth
    // NOTE: Security is now handled at the application level via the Admin Panel UI
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'description', 'type', 'url', 'posterUrl', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 1000 &&
             data.type in ['video', 'website', 'game'] &&
             data.url is string && data.url.size() <= 2000 &&
             data.posterUrl is string && data.posterUrl.size() <= 2000;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /projects/{projectId} {
      allow get, list: if true;
      
      // Allow creation/updates/deletion globally for synchronization
      allow create: if isValidId(projectId) && 
                      isValidProject(incoming());
                      
      allow update: if isValidProject(incoming());
                      
      allow delete: if true;
    }
  }
}
